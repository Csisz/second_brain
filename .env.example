# API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=second_brain

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Claude model
CLAUDE_MODEL=claude-sonnet-4-6

# Telegram Bot (Fázis 3-ban töltsd ki)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Synology NAS (Fázis 2-ben töltsd ki)
SYNOLOGY_HOST=
SYNOLOGY_PORT=5000
SYNOLOGY_USER=
SYNOLOGY_PASS=
SYNOLOGY_FOLDER=/MUNKA

# Gmail OAuth (Fázis 2-ben töltsd ki)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
